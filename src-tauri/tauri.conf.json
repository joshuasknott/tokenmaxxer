{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TokenMaxxer",
  "version": "0.1.0",
  "identifier": "com.tokenmaxxer.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "TokenMaxxer",
        "width": 760,
        "height": 720,
        "minWidth": 520,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "category": "DeveloperTool",
    "licenseFile": "../LICENSE",
    "publisher": "Josh Knott",
    "homepage": "https://github.com/joshuasknott/tokenmaxxer",
    "shortDescription": "Local-first desktop usage tracker for LLM subscriptions.",
    "longDescription": "TokenMaxxer tracks AI subscription limits, API key balances, reset windows, and estimated spend locally on Windows, macOS, and Linux.",
    "icon": [
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/joshuasknott/tokenmaxxer/releases/latest/download/latest.json"
      ],
      "pubkey": "REPLACE_WITH_TAURI_UPDATER_PUBLIC_KEY",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
