{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TokenMaxxer",
  "version": "0.1.0",
  "identifier": "com.tokenmaxxer.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Usage",
        "width": 760,
        "height": 720,
        "minWidth": 520,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
